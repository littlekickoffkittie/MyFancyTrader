# ── Phemex ───────────────────────────────────────────────────────
PHEMEX_API_KEY=your_api_key_here
PHEMEX_API_SECRET=your_api_secret_here
PHEMEX_BASE_URL=https://api.phemex.com
# Use testnet while verifying cloud setup:
# PHEMEX_BASE_URL=https://testnet-api.phemex.com

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Use the SERVICE ROLE key (not anon) — gives the bot full DB access
SUPABASE_SERVICE_KEY=eyJhbGci...

# ── Telegram ─────────────────────────────────────────────────────
# Your bot token from @BotFather
TG_BOT_TOKEN=8138530353:AAEiUcGoBMOdAxNXVSVJpNFu570lngyPdsM
# Your personal chat ID (use @userinfobot to find it)
TG_CHAT_ID=7952819982

# ── Bot tuning ───────────────────────────────────────────────────
